# Backend API URL (required). Use the backend you are talking to.
# - Both local:     http://localhost:5000/api
# - Local + remote: https://your-backend.koyeb.app/api  (backend must set ALLOW_LOCALHOST=true for CORS)
# - Production:     https://your-backend.koyeb.app/api
VITE_API_BASE_URL=http://localhost:5000/api

# Uploads base URL — backend origin without /api. If unset, derived from VITE_API_BASE_URL.
# - Both local:     http://localhost:5000  (or leave unset)
# - Live backend:   https://your-backend.koyeb.app
VITE_UPLOADS_BASE_URL=http://localhost:5000

# Optional
# VITE_STRIPE_PUBLISHABLE_KEY=pk_...
